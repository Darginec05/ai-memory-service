# Required: used for fact extraction (gpt-4o-mini) and embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Optional: if set, all endpoints except /health require "Authorization: Bearer <token>"
MEMORY_AUTH_TOKEN=

# Optional: debug | info | warn | error (default info). debug dumps full pipeline
# state — retrieval rankings, rerank prompts, extraction candidates.
LOG_LEVEL=info

# Local development only (npm run dev): point the service at the dockerized Postgres,
# which is exposed on host port 5433. Not needed when running via docker compose.
DATABASE_URL=postgres://memory:memory@localhost:5433/memory
