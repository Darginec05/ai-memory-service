{
  "name": "memory-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx scripts/eval.ts",
    "test": "vitest run tests/unit tests/contract",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:persistence": "vitest run tests/persistence"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "openai": "^5.0.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
